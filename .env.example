SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key

# Never expose service role keys in browser code.
# Use service role keys only inside Supabase Edge Functions or another secure server.
SUPABASE_SERVICE_ROLE_KEY=server-only-do-not-commit

# Future AI integration must run server-side only.
OPENAI_API_KEY=server-only-do-not-commit
